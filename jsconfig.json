{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "checkJs": false,
    "skipLibCheck": true,
    "noEmit": true
  },
  "exclude": [
    "node_modules/**/*",
    "**/node_modules/**/*",
    "node_modules"
  ],
  "include": ["**/*.js"],
  "typeAcquisition": {
    "enable": false
  }
}